FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Naver Search API
NAVER_CLIENT_ID=
